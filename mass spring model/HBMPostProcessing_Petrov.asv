%% plot Amplitude vs omega


[E, EH] = HBM.fft_matrices(N, H);
for i = 1:3*Nx + Na
    x_contNx(:,:,i) = x_cont((2*H+1)*(i-1)+1:(2*H+1)*i,:);
end
Adof = omega_cont';
for Ndof = 1:3*Nx + Na
    A = E * x_contNx(:,:,Ndof);
    Amax = max(abs(A));
    Adof(:, Ndof + 1) = Amax';
end
Adof = [Adof, k_cont'];


figure;
semilogy(Adof(:, 1), Adof(:, 3), 'b-.', 'LineWidth', 2), hold on;
semilogy(Adof(:, 1), Adof(:, 5), 'r-', 'LineWidth', 2), grid on;
ylim([0.1, 100]);
leg