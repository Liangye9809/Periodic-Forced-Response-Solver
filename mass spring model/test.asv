plot(N_b.Adof(end, 1), N_b.Adof(end, 3), 'ko', 'MarkerSize', 4), grid on;
plot(N_b.Adof(end, 1), N_b.Adof(end, 5), 'ko', 'MarkerSize', 4), grid on;
plot([N_b.Adof(end, 1), N_b.Adof(end, 1)], [0, 40], 'k--', 'LineWidth', 2), grid on;
% str = 'Omega_fail = ' + string(N_b.Adof(end, 1));
% text(N_f.Adof(end, 1), 20, str);

xlim([4 ,16]);
ylim([0 ,40]);
titlename = 'H = 5, N = 128, ds = 0.09, backward, Omega_fail = ' + string(N_b.Adof(end, 1));
title(titlename);

%%
P_N = load('Numerical_2DOF_nonPetrov.mat');
P_F = load('Numerical_Fixed_2DOF_nonPetrov.mat');
H = 5; Nx = 1; Na = 1;
[E, EH] = HBM.fft_matrices(2^12, H);
for i = 1:3*Nx + Na
    x_contNx_N(:,:,i) = P_N.P.x_cont((2*H+1)*(i-1)+1:(2*H+1)*i,:);
    x_contNx_F(:,:,i) = P_F.P.x_cont((2*H+1)*(i-1)+1:(2*H+1)*i,:);
end
Adof_N = P_N.P.Adof(:, 1);
Adof_F = P_F.P.Adof(:, 1);
for Ndof = 1:3*Nx + Na
    A_N = E * x_contNx_N(:,:,Ndof);
    Amax_N = max(abs(A_N));
    Adof_N(:, Ndof + 1) = Amax_N';

    A_F = E * x_contNx_F(:,:,Ndof);
    Amax_F = max(abs(A_F));
    Adof_F(:, Ndof + 1) = Amax_F';
end
% OMEGA = sqrt(omega02) .* omega_cont';
% OMEGA = omega_cont';
% Adof = [Adof, k_cont'];

% Adof_F = P_F.P.Adof;
% Adof_N = P_N.P.Adof;
for i = 1:4
    figure;
    plot(Adof_F(:, 1), Adof_F(:, i + 1), 'b-','DisplayName', 'Fixed Numerical','LineWidth', 2), hold on;
    plot(Adof_N(:, 1), Adof_N(:, i + 1), 'r-','DisplayName', 'Original Numerical','LineWidth', 2), grid on;
    legend show;
end
for i = 1:4
    figure;
    plot(P_F.P.Adof(:,1)',P_F.P.x_cont((2))), hold on;
    plot(P_N.P.Adof(:,1)',P_N.P.x_cont), grid on;