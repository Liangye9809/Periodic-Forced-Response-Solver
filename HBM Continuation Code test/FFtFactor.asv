function ft_out = FFtFactor(ft_in, xt, flag, kt, kn, mu)
    ft_out = ft_in;
    [N, Nx] = size(xt);
    Nx = Nx / 3;
    for i = 1:Nx
        flagT1(:, 1) = flag(1, i, :);
        flagT2(:, 1) = flag(2, i, :);
        xn = xt(:, 3 * i);
        xt1 = xt(:, 3 * i - 2);
        xt2 = xt(:, 3 * i - 1);
        ft_out(:, 3 * i - 2) = FFtFactor_perT(ft_in(:, 3 * i - 2), xt1, xn, flagT1, kt(1, i), kn(i), mu(1, i));
        ft_out(:, 3 * i - 1) = FFtFactor_perT(ft_in(:, 3 * i - 2), xt1, xn, flagT1, kt(1, i), kn(i), mu(1, i));
end

function Ft_out = FFtFactor_perT(Ft_in, xt, xn, flag, kt, kn, mu) % all the dofs of xt, and Ft
    Ft_out = Ft_in;
    N = size(xt, 1);
    % slip and stick transiton
    diffs = [diff(flag); flag(1) - flag(end)];
    ind = ismember(diffs, [1, -1, 3, -3]); % possible slip - stick transition
    trans_ss = find(ind == 1);
    for j = 1:size(trans_ss, 1)
        i_m = trans_ss(j);
        i_p = mod(i_m, N) + 1; % next point
        if flag1(i_m) == 2 % stick to slip
            f1_m = Ft_in(i_m); % Ft-
            f1_p = f1_m + kt * (xt(i_p) - xt(i_m));
            f2_p = Ft_in(i_p); % Ft+
            f2_m = sign(f1_m) * mu * kn * xn(i_m);
            [Ft_out(i_m), Ft_out(i_p)] = scaleSlipStick(f1_m, f1_p, f2_m, f2_p);
        end
        % if flag1(i_p) == 2 % slip to stick
        %     f1_m = Ft_in(i_m, 3 * i - 2); % Ft-
        %     f1_p = sign(f1_m) * mu(i) * kn(i) * xn(i_m);
        %     f2_p = Ft_in(i_p, 3 * i - 2); % Ft+
        %     f2_m = f2_p - kt(1, i) * (xt1(i_p) - xt1(i_m));    
        %     [Ft_out(i_m, 3 * i - 2), Ft_out(i_p, 3 * i - 2)] = scaleSlipStick(f1_m, f1_p, f2_m, f2_p);
        % end
        
    end


end

function [Ft_m, Ft_p] = scaleSlipStick(f1_m, f1_p, f2_m, f2_p)
    fdt = (f2_m - f1_m) / (f1_p - f1_m + f2_m - f2_p);
    f_star = f1_m + (f1_p - f1_m) * fdt;
    Ft_m = f1_m * 0.5 * (1 + fdt) + 0.5 * (1 - fdt) * f_star;
    Ft_p = f2_p * 0.5 * (2 - fdt) + 0.5 * fdt * f_star;
end