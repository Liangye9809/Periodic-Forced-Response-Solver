function Ft_out = FFtFactor_perT(Ft_in, xt, flag, kt, kn, mu) % all the dofs of xt, and Ft
    Ft_out = Ft_in;
    
    for i = 1:Nx
        % slip and stick transiton
        diffs = [diff(flag(:, i)); flag(1, i) - flag(end, i)];
        ind = ismember(diffs, [1,-1,3,-3]);
        trans_ss = find(ind == 1);
        for j = 1:size(trans_ss, 1)
            i_m = trans_ss(j);
            i_p = mod(i_m, N) + 1; % next point
            if flag1(i_m) == 2 % stick to slip
                f1_m = Ft_in(i_m); % Ft-
                f1_p = f1_m + kt(1, i) * (xt1(i_p) - xt1(i_m));
                f2_p = Ft_in(i_p); % Ft+
                f2_m = sign(f2_p) * mu(i) * kn(i) * xn(i_m);    
                [Ft_out(i_m), Ft_out(i_p)] = scaleSlipStick(f1_m, f1_p, f2_m, f2_p);
            end
            % if flag1(i_p) == 2 % slip to stick
            %     f1_m = Ft_in(i_m, 3 * i - 2); % Ft-
            %     f1_p = sign(f1_m) * mu(i) * kn(i) * xn(i_m);
            %     f2_p = Ft_in(i_p, 3 * i - 2); % Ft+
            %     f2_m = f2_p - kt(1, i) * (xt1(i_p) - xt1(i_m));    
            %     [Ft_out(i_m, 3 * i - 2), Ft_out(i_p, 3 * i - 2)] = scaleSlipStick(f1_m, f1_p, f2_m, f2_p);
            % end
            
        end

    end

end

function [Ft_m, Ft_p] = scaleSlipStick(f1_m, f1_p, f2_m, f2_p)
    fdt = (f2_m - f1_m) / (f1_p - f1_m + f2_m - f2_p);
    f_star = f1_m + (f1_p - f1_m) * fdt;
    Ft_m = f1_m * 0.5 * (1 + fdt) + 0.5 * (1 - fdt) * f_star;
    Ft_p = f2_p * 0.5 * (2 - fdt) + 0.5 * fdt * f_star;
end